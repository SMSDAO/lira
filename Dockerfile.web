# Web front-end — Next.js multi-stage build
# Produces a standalone Next.js output for minimal Docker image size.

# ── Stage 1: Dependencies ────────────────────────────────────────────────────
FROM node:24-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
# Install all deps (including devDependencies) so ts-node is available for build
RUN npm ci

# ── Stage 2: Build ───────────────────────────────────────────────────────────
FROM node:24-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Supply minimal build-time env so validate-env.ts passes
ENV NODE_ENV=production \
    NEXT_PUBLIC_CHAIN_ID=84532 \
    NEXT_PUBLIC_CHAIN_NAME="Base Sepolia" \
    DATABASE_URL="postgresql://placeholder:placeholder@localhost:5432/lira"

RUN npm run build

# ── Stage 3: Runtime ─────────────────────────────────────────────────────────
FROM node:24-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production

COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000
HEALTHCHECK --interval=15s --timeout=5s --retries=3 \
    CMD wget -qO- http://localhost:3000/api/health || exit 1

CMD ["node", "server.js"]
